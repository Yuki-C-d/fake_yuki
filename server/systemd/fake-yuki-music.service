[Unit]
Description=fake_yuki Music Station
After=network.target ncmapi.service
Requires=ncmapi.service

[Service]
Type=simple
WorkingDirectory=/opt/fake_yuki
Environment=YUKI_MUSIC_DIR=/opt/fake_yuki/music-files
ExecStart=/usr/bin/python3 -m uvicorn apps.music.backend.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
